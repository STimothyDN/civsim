# Leave as / for root-domain deployments.
VITE_BASE_PATH=/

# Optional local LLM settings for election climate naming and the Election Narrative modal.
VITE_LMSTUDIO_ENDPOINT=http://localhost:1234/v1/chat/completions
VITE_LMSTUDIO_MODEL=google/gemma-4-e4b
